{
	"name": "@jis3r/icons",
	"version": "2.8.0",
	"description": "beautifully crafted, moving icons. for svelte.",
	"keywords": [
		"svelte",
		"icons",
		"lucide",
		"animated",
		"beautiful",
		"moving"
	],
	"author": "jis3r",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jis3r/icons.git"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"package": "svelte-kit sync && svelte-package && publint",
		"prepublishOnly": "npm run package",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:icons": "tsx scripts/checkIcons.ts",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"index": "tsx scripts/indexIcons.ts && prettier --write src/lib-docs/icons-meta.ts",
		"reexport": "tsx scripts/generateIconExports.ts",
		"registry:build": "npm run reexport && node scripts/updateRegistry.js && node scripts/buildRegistry.js",
		"prep": "npm run index && npm run reexport && npm run registry:build && npm run build && npm run package && npm run format"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": false,
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./icons/*": {
			"types": "./dist/icons/*.svelte.d.ts",
			"svelte": "./dist/icons/*.svelte"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@lucide/svelte": "^0.575.0",
		"@number-flow/svelte": "^0.3.6",
		"@sveltejs/adapter-auto": "^6.0.1",
		"@sveltejs/kit": "^2.26.1",
		"@sveltejs/package": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.1.16",
		"@types/eslint": "^9.6.0",
		"@types/node": "^26.1.1",
		"autoprefixer": "^10.4.20",
		"bits-ui": "^2.16.2",
		"clsx": "^2.1.1",
		"eslint": "^9.7.0",
		"eslint-config-prettier": "^10.1.1",
		"eslint-plugin-svelte": "^3.5.1",
		"geist-svelte": "^1.0.0",
		"globals": "^16.0.0",
		"jsdom": "^29.1.1",
		"mode-watcher": "^0.5.1",
		"motion": "^12.23.24",
		"posthog-js": "^1.246.0",
		"prettier": "^3.3.2",
		"prettier-plugin-svelte": "^3.2.6",
		"prettier-plugin-tailwindcss": "^0.7.1",
		"publint": "^0.3.10",
		"shadcn-svelte": "^1.0.6",
		"svelte": "^5.0.0",
		"svelte-check": "^4.7.2",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.16",
		"tailwindcss-animate": "^1.0.7",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.3.2",
		"typescript-eslint": "^8.63.0",
		"vite": "^8.0.16",
		"vitest": "^4.1.0"
	},
	"overrides": {
		"cookie": "0.7.0"
	},
	"allowScripts": {
		"esbuild@0.28.1": true,
		"fsevents@2.3.3": true,
		"core-js@3.49.0": true
	}
}
